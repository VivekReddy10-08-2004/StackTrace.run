# Copy to backend/.env and fill in. All values are optional in dev —
# the backend falls back to a local SQLite file and disables GitHub OAuth
# until creds are present.

# --- Database (§1) ---
# Leave unset for local dev (uses backend/local_dev.db).
# DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-token

# --- Auth / JWT (§2) ---
# REQUIRED in production. Generate: python -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=
JWT_TTL_SECONDS=3600

# --- GitHub OAuth (§2) ---
# Register at https://github.com/settings/developers (separate dev/prod apps).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/github/callback

# --- Frontend / sharing (§3) ---
FRONTEND_URL=http://localhost:4321
PUBLIC_BASE_URL=http://localhost:8000

# --- CORS (§4): explicit allow-list, comma-separated ---
CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321
